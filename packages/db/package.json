{
  "name": "@hype/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -c -- prisma migrate dev",
    "db:deploy": "dotenv -e ../../.env -c -- prisma migrate deploy",
    "db:seed": "tsx src/seed.ts"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@hype/core": "workspace:*",
    "@prisma/client": "^6.10.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "prisma": "^6.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "dotenv-cli": "^8.0.0"
  }
}
