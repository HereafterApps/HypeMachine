# --- Database ---
DATABASE_URL=postgresql://hype:hype@localhost:5432/hype_machine

# --- Redis (BullMQ queues) ---
REDIS_URL=redis://localhost:6379

# --- API ---
API_PORT=4000
# Single-user auth token (v1). Every API request must send
# Authorization: Bearer <API_TOKEN>
API_TOKEN=change-me

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- AI providers ---
ANTHROPIC_API_KEY=

# --- Storage ---
# "local" writes to ./storage; "s3" uses the S3 config below
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Notifications ---
DISCORD_WEBHOOK_URL=
