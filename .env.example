# Copy to .env at the repo root — every process (API, Prisma, Next.js)
# loads this file automatically.

# --- Database ---
DATABASE_URL=postgresql://hype:hype@localhost:5432/hype_machine

# --- Redis (BullMQ queues, Phase 3+) ---
REDIS_URL=redis://localhost:6379

# --- API ---
API_PORT=4000
# Single-user auth (v1). Every API request must send
# Authorization: Bearer <API_TOKEN>. The API refuses to start without it
# unless DISABLE_AUTH=true (local development only!).
API_TOKEN=change-me
# DISABLE_AUTH=true

# Comma-separated allowed CORS origins. Defaults to http://localhost:3000.
# CORS_ORIGIN=http://localhost:3000

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:4000
# The web server reuses API_TOKEN above for its server-side API calls.
# Never put the token in a NEXT_PUBLIC_ variable — those are shipped to
# the browser.

# --- AI providers ---
ANTHROPIC_API_KEY=

# --- Notifications ---
# Discord webhook that receives "content awaiting approval" messages.
DISCORD_WEBHOOK_URL=
# Base URL used in notification links to the dashboard.
WEB_URL=http://localhost:3000

# --- Storage (Phase 4+) ---
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
