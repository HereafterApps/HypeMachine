# --- Database / queue ---
DATABASE_URL=postgresql://hype@127.0.0.1:54329/hype_machine
REDIS_URL=redis://127.0.0.1:63790

# --- API ---
API_PORT=3001
# Single-user auth (v1): every request must send `Authorization: Bearer <token>`
API_TOKEN=change-me

# --- Pipeline service (apps/pipeline — Python/FastAPI) ---
# The TS API delegates generation/guardrails/insights here.
PIPELINE_URL=http://127.0.0.1:8300
PIPELINE_TOKEN=dev-pipeline-token
# Read by the pipeline service itself:
# "anthropic" for real generation, "stub" for deterministic keyless dev/demo
LLM_PROVIDER=stub
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Storage (packages/storage) ---
# "local" writes under ./storage, "s3" uses the AWS SDK
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Notifications ---
# Comma-separated: console,discord,email
NOTIFY_CHANNELS=console
DISCORD_WEBHOOK_URL=
SES_REGION=
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=

# --- App ---
# Base URL used in approval links inside notifications
DASHBOARD_BASE_URL=http://localhost:3000
# Secret used to encrypt platform tokens at rest (32+ chars)
TOKEN_ENCRYPTION_KEY=dev-only-encryption-key-change-me
