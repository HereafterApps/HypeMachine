{
  "name": "hype-machine",
  "version": "0.1.0",
  "private": true,
  "description": "Persona-first AI content creation and publishing platform",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev:api": "pnpm --filter @hype/api dev",
    "dev:web": "pnpm --filter @hype/web dev",
    "db:generate": "pnpm --filter @hype/db generate",
    "db:migrate": "pnpm --filter @hype/db migrate"
  }
}
